{
  "name": "vynce-frontend",
  "private": true,
  "version": "1.0.1",
  "description": "Vynce Desktop - Commercial desktop application for managing calls and communications",
  "author": "Vynce",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:e2e:staged": "node scripts/staged-control-plane-e2e.mjs",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5174 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5174 electron electron/main.cjs\"",
    "electron:renderer:build": "vite build --config vite.electron.config.js",
    "electron:pack": "npm run electron:renderer:build && electron-builder --dir",
    "electron:dist": "npm run electron:renderer:build && electron-builder",
    "electron:portable": "npm run electron:renderer:build && electron-builder --win portable",
    "electron:mac": "npm run electron:renderer:build && electron-builder --mac dmg zip",
    "electron:linux": "npm run electron:renderer:build && electron-builder --linux AppImage deb"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.9.6",
    "recharts": "^2.15.4",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.22",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^32.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.4.0",
    "vite": "^5.2.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.vynce.desktop",
    "productName": "Vynce Desktop",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "buildResources": "public"
    },
    "files": [
      "electron/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "category": "Office",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "deb": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    }
  }
}
