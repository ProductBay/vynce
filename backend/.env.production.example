NODE_ENV=production
PORT=3000

# Core app
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
MONGODB_URI=REPLACE_WITH_PRODUCTION_MONGODB_URI
CORS_ORIGIN=https://app.example.com
PUBLIC_WEBHOOK_URL=https://api.example.com

# Vonage
VONAGE_API_KEY=REPLACE_WITH_VONAGE_API_KEY
VONAGE_API_SECRET=REPLACE_WITH_VONAGE_API_SECRET
VONAGE_APPLICATION_ID=REPLACE_WITH_VONAGE_APPLICATION_ID
VONAGE_PRIVATE_KEY_PATH=REPLACE_WITH_ABSOLUTE_PRIVATE_KEY_PATH
VONAGE_API_SIGNATURE_SECRET=REPLACE_WITH_VONAGE_SIGNATURE_SECRET

# Licensing
LICENSE_SOURCE=control_plane
CONTROL_PLANE_BASE_URL=https://control-plane.example.com
CONTROL_PLANE_API_SECRET=REPLACE_WITH_CONTROL_PLANE_ADMIN_SECRET
CONTROL_PLANE_TIMEOUT_MS=8000
VYNCE_LICENSE_TOKEN=REPLACE_WITH_LICENSE_TOKEN
VYNCE_ACTIVATION_ID=REPLACE_WITH_ACTIVATION_ID

# Support
SUPPORT_PROVIDER_WEBHOOK_SECRET=REPLACE_WITH_SUPPORT_PROVIDER_WEBHOOK_SECRET

# Runtime
OFFLINE_MODE=false
VONAGE_ENFORCE_SIGNED_WEBHOOKS=true
VONAGE_WEBHOOK_AUDIT=false
