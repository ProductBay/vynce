# ==============================
# Vonage Configuration
# ==============================
VONAGE_API_KEY=REPLACE_WITH_VONAGE_API_KEY
VONAGE_API_SECRET=REPLACE_WITH_VONAGE_API_SECRET
VONAGE_APPLICATION_ID=REPLACE_WITH_VONAGE_APPLICATION_ID
CALLER_ID=+15555550123
VONAGE_PRIVATE_KEY_PATH=./private.key
VONAGE_PHONE_NUMBER=+15555550123
FORWARD_TO_NUMBER=+15555550124
VONAGE_API_SIGNATURE_SECRET=REPLACE_WITH_VONAGE_WEBHOOK_SIGNATURE_SECRET
VONAGE_ENFORCE_SIGNED_WEBHOOKS=true
VONAGE_PLAN_NAME=Vonage Voice Account
VONAGE_DASHBOARD_URL=https://dashboard.vonage.com

# ==============================
# Database
# ==============================
MONGODB_URI=REPLACE_WITH_MONGODB_URI

# ==============================
# JWT / Auth
# ==============================
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_JWT_SECRET

# ==============================
# License System
# ==============================
LICENSE_SOURCE=control_plane
LICENSE_SERVER_URL=http://localhost:8080
VYNCE_LICENSE_TOKEN=PASTE_YOUR_LICENSE_JWT_HERE
VYNCE_ACTIVATION_ID=ACT-REPLACE-WITH-YOUR-ACTIVATION-ID
LICENSE_PUBLIC_KEY=OPTIONAL_PUBLIC_KEY_IF_USED
CONTROL_PLANE_BASE_URL=https://control-plane.example.com
CONTROL_PLANE_ADMIN_SECRET=REPLACE_WITH_CONTROL_PLANE_ADMIN_SECRET
CONTROL_PLANE_API_SECRET=REPLACE_WITH_CONTROL_PLANE_ADMIN_SECRET
CONTROL_PLANE_TIMEOUT_MS=8000
APP_ENV=development

# ==============================
# Server
# ==============================
PORT=3000
NODE_ENV=development
PUBLIC_WEBHOOK_URL=https://replace-with-your-public-webhook.example.com
CORS_ORIGIN=http://127.0.0.1:5174
OFFLINE_MODE=false
OFFLINE_ADMIN_EMAIL=admin@offline.local
OFFLINE_ADMIN_PASSWORD=CHANGE_ME_FOR_LOCAL_ONLY
SUPPORT_PROVIDER_WEBHOOK_SECRET=REPLACE_WITH_SUPPORT_WEBHOOK_SECRET
